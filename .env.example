# Pace BMS RS232 Monitor - standalone Docker example
#
# Copy this file to .env before running docker compose:
#   copy .env.example .env
#
# Do not commit .env. It may contain MQTT and Telegram secrets.

# Web UI
PACEBMS_WEB_PORT=8099

# Serial device exposed to the container.
# On Linux this is commonly /dev/ttyUSB0. You may also use a stable
# /dev/serial/by-id/... path if Docker can map it on your host.
PACEBMS_SERIAL_DEVICE=/dev/ttyUSB0
PACEBMS_BMS_CONNECTION_MODE=Serial
PACEBMS_BMS_BAUDRATE=9600
PACEBMS_SCAN_INTERVAL=5

# Live UI and local history
PACEBMS_UI_DATA_SOURCE=auto
PACEBMS_METRICS_ENABLED=true
PACEBMS_HISTORY_SAMPLE_SECONDS=10
PACEBMS_HISTORY_CELL_SAMPLE_SECONDS=30
PACEBMS_HISTORY_RETENTION_DAYS=90
PACEBMS_HISTORY_EVENT_RETENTION_DAYS=365

# MQTT optional output/fallback. Leave disabled for serial-only monitoring.
PACEBMS_MQTT_ENABLED=false
PACEBMS_MQTT_HOST=192.168.1.10
PACEBMS_MQTT_PORT=1883
PACEBMS_MQTT_USER=YOUR_MQTT_USER
PACEBMS_MQTT_PASSWORD=YOUR_MQTT_PASSWORD
PACEBMS_MQTT_BASE_TOPIC=pacebms
PACEBMS_MQTT_HA_DISCOVERY=true
PACEBMS_MQTT_HA_DISCOVERY_TOPIC=homeassistant
PACEBMS_MQTT_RETAIN_STATE=true
PACEBMS_STATE_FORCE_REPUBLISH_SECONDS=300
PACEBMS_WARN_FORCE_REPUBLISH_SECONDS=300

# Telegram direct notifications
PACEBMS_NOTIFY_ENABLED=true
PACEBMS_TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
PACEBMS_TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# 0 normal, 1 summary troubleshooting, 2 poll troubleshooting, 3 raw protocol troubleshooting
PACEBMS_DEBUG_OUTPUT=0

# auto, p13s_hubble_am2, p16s_eenovance_mana, custom
PACEBMS_BATTERY_PROFILE=auto

# Optional read-only setup checks. Use 0 for auto/detected.
PACEBMS_EXPECTED_CELL_COUNT=0
PACEBMS_EXPECTED_PACK_COUNT=0

# Optional capacity fallback for estimates only when BMS capacity is unavailable.
PACEBMS_CAPACITY_FALLBACK_ENABLED=false
PACEBMS_CAPACITY_PER_PACK_AH=0
